{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecurityRetentionRedactionPolicy",
  "type": "object",
  "required": ["version", "retention_days", "immutable_artifacts", "redaction_levels", "pii_field_patterns", "secrets_field_patterns", "audit_log_scope"],
  "properties": {
    "version": { "type": "string", "const": "v1" },
    "retention_days": { "type": "integer", "minimum": 1 },
    "immutable_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "redaction_levels": {
      "type": "array",
      "items": { "type": "string", "enum": ["none", "partial", "full"] },
      "minItems": 3
    },
    "pii_field_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "secrets_field_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "audit_log_scope": {
      "type": "object",
      "required": ["immutable", "append_only", "required_fields", "retention_days"],
      "properties": {
        "immutable": { "type": "boolean", "const": true },
        "append_only": { "type": "boolean", "const": true },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        },
        "retention_days": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
