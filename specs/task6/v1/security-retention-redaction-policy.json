{
  "version": "v1",
  "retention_days": 90,
  "immutable_artifacts": [
    "VerificationArtifact.json",
    "evidence_records.json",
    "proof.json",
    "trace.jsonl",
    "manifest.json"
  ],
  "redaction_levels": ["none", "standard", "strict"],
  "pii_field_patterns": [
    "email",
    "phone",
    "ssn",
    "name",
    "address",
    "date_of_birth"
  ],
  "secrets_field_patterns": [
    "api_key",
    "secret",
    "token",
    "password",
    "credential",
    "private_key"
  ],
  "audit_log_scope": {
    "include_events": ["state_transition", "escalation", "approval", "rejection", "evidence_collected", "proof_generated"],
    "exclude_fields": ["password", "token", "secret", "api_key", "private_key", "credential"]
  }
}
