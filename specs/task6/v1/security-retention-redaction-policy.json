{
  "version": "v1",
  "retention_days": 90,
  "immutable_artifacts": [
    "VerificationArtifact.json",
    "evidence_records.json",
    "proof.json",
    "trace.jsonl",
    "manifest.json"
  ],
  "redaction_levels": ["none", "partial", "full"],
  "pii_field_patterns": [
    "email",
    "phone",
    "ssn",
    "name",
    "address",
    "date_of_birth"
  ],
  "secrets_field_patterns": [
    "api_key",
    "secret",
    "token",
    "password",
    "credential",
    "private_key"
  ],
  "audit_log_scope": {
    "immutable": true,
    "append_only": true,
    "required_fields": ["timestamp", "actor", "action", "resource", "outcome"],
    "retention_days": 90
  }
}
