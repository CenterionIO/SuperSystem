{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orchestrator-Planner Interface v1",
  "version": "1.0.0",
  "description": "Concrete I/O contract between Orchestrator and Planner. Orchestrator sends PlanningRequest, Planner returns ExecutionPlan. Neither may write the other's fields.",

  "PlanningRequest": {
    "description": "Sent by Orchestrator to Planner. Contains routing context but NO plan content.",
    "type": "object",
    "required": ["correlation_id", "workflow_class", "autonomy_mode", "research_report_id", "request_summary", "constraints"],
    "properties": {
      "correlation_id": {
        "type": "string",
        "format": "uuid",
        "description": "End-to-end trace ID. Set by Orchestrator, immutable downstream."
      },
      "workflow_class": {
        "type": "string",
        "enum": ["code_change", "mcp_tool", "research_only", "transcription", "ui_change", "ops_fix"],
        "description": "Classified by Orchestrator. Planner may read but MUST NOT mutate."
      },
      "autonomy_mode": {
        "type": "string",
        "enum": ["approve_each", "approve_final", "full_auto"],
        "description": "Set by policy/user. Planner may read to adjust plan granularity but MUST NOT mutate."
      },
      "research_report_id": {
        "type": ["string", "null"],
        "description": "Reference to ResearchReport in evidence registry. Null if research was not required."
      },
      "request_summary": {
        "type": "string",
        "description": "Normalized user intent from Operator, passed through by Orchestrator."
      },
      "constraints": {
        "type": "object",
        "description": "Bounds set by Orchestrator: max steps, path scope, tool scope.",
        "properties": {
          "max_plan_steps": { "type": "integer", "minimum": 1 },
          "allowed_paths": {
            "type": "array",
            "items": { "type": "string" },
            "description": "File/directory paths the plan may target."
          },
          "allowed_tools": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Tool IDs the plan may reference."
          },
          "denied_tools": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Tool IDs explicitly forbidden."
          }
        }
      }
    },
    "fieldOwnership": {
      "/correlation_id":                  { "writtenBy": ["Orchestrator"], "readableBy": ["*"],       "verifiedBy": ["VerifyMCP"] },
      "/workflow_class":                  { "writtenBy": ["Orchestrator"], "readableBy": ["*"],       "verifiedBy": ["VerifyMCP"] },
      "/autonomy_mode":                   { "writtenBy": ["Orchestrator"], "readableBy": ["*"],       "verifiedBy": ["VerifyMCP"] },
      "/research_report_id":              { "writtenBy": ["Orchestrator"], "readableBy": ["Planner", "VerifyMCP"], "verifiedBy": ["VerifyMCP"] },
      "/request_summary":                 { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] },
      "/constraints":                     { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] },
      "/constraints/max_plan_steps":      { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] },
      "/constraints/allowed_paths":       { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] },
      "/constraints/allowed_paths/[]":    { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] },
      "/constraints/allowed_tools":       { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] },
      "/constraints/allowed_tools/[]":    { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] },
      "/constraints/denied_tools":        { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] },
      "/constraints/denied_tools/[]":     { "writtenBy": ["Orchestrator"], "readableBy": ["Planner"], "verifiedBy": ["VerifyMCP"] }
    }
  },

  "PlanningResponse": {
    "description": "Returned by Planner to Orchestrator. Contains plan content but NO routing mutations.",
    "type": "object",
    "required": ["correlation_id", "execution_plan_id", "status", "execution_plan"],
    "properties": {
      "correlation_id": {
        "type": "string",
        "format": "uuid",
        "description": "Echo of the request correlation_id. Planner MUST NOT generate a new one."
      },
      "execution_plan_id": {
        "type": "string",
        "format": "uuid",
        "description": "Unique ID for this plan version. Generated by Planner."
      },
      "status": {
        "type": "string",
        "enum": ["ready", "needs_research", "plan_blocker"],
        "description": "Planner's assessment. Orchestrator reads this to decide next routing."
      },
      "plan_blocker_detail": {
        "type": ["string", "null"],
        "description": "Required when status is plan_blocker. Describes what is missing or ambiguous."
      },
      "execution_plan": {
        "$ref": "schemas/v1/ExecutionPlan.json",
        "description": "The authored plan. Null only when status is needs_research."
      }
    },
    "fieldOwnership": {
      "/correlation_id":        { "writtenBy": ["Orchestrator"], "readableBy": ["Orchestrator", "VerifyMCP"], "verifiedBy": ["VerifyMCP"], "echoedBy": ["Planner"] },
      "/execution_plan_id":     { "writtenBy": ["Planner"],      "readableBy": ["*"],                        "verifiedBy": ["VerifyMCP"] },
      "/status":                { "writtenBy": ["Planner"],      "readableBy": ["Orchestrator"],              "verifiedBy": ["VerifyMCP"] },
      "/plan_blocker_detail":   { "writtenBy": ["Planner"],      "readableBy": ["Orchestrator", "Planner"],   "verifiedBy": ["VerifyMCP"] },
      "/execution_plan":        { "writtenBy": ["Planner"],      "readableBy": ["Orchestrator", "Builder", "VerifyMCP"], "verifiedBy": ["VerifyMCP"] }
    }
  },

  "boundaryRules": {
    "description": "Explicit rules enforced at the Orchestrator-Planner boundary.",
    "rules": [
      {
        "id": "OP-001",
        "rule": "Planner MUST NOT mutate: workflow_class, autonomy_mode, correlation_id (generation), routing_decision, state_transition.",
        "enforced_by": "runtime_guard",
        "gate": "authority_conformance"
      },
      {
        "id": "OP-002",
        "rule": "Orchestrator MUST NOT mutate: execution_plan content fields (steps, criteria_ids, acceptance_criteria, verification_requirements).",
        "enforced_by": "runtime_guard",
        "gate": "orchestrator_boundary"
      },
      {
        "id": "OP-003",
        "rule": "PlanningResponse.correlation_id MUST be byte-identical to PlanningRequest.correlation_id. Planner echoes but MUST NOT generate, modify, or omit this value.",
        "enforced_by": "runtime_guard",
        "gate": "authority_conformance",
        "check_type": "value_equality",
        "lhs": "PlanningRequest.correlation_id",
        "rhs": "PlanningResponse.correlation_id"
      },
      {
        "id": "OP-004",
        "rule": "PlanningResponse.status == 'plan_blocker' MUST include non-null plan_blocker_detail.",
        "enforced_by": "runtime_guard",
        "gate": "authority_conformance"
      },
      {
        "id": "OP-005",
        "rule": "Every step in execution_plan MUST contain at least one criteria_id.",
        "enforced_by": "runtime_guard",
        "gate": "authority_conformance"
      }
    ]
  }
}
